# =====================================================================
# Vibe Tax Research Chat — installer-managed environment file
# =====================================================================
# Rendered into /etc/vibe/tax/.env on first install.
#
# Prereq T-A: the upstream Vibe-Tax-Research-Chat repo must publish
# vibe-tax-{api,web} images to GHCR before this app can be installed.
# The release.yml workflow on branch feat/installer-readiness adds the
# publish job.
#
# Prereq T-B: the upstream repo must expose runtime base-path
# substitution (the docker-entrypoint.d/40-base-path.sh hook) so the
# multi-app overlay's VITE_BASE_PATH=/tax/ has somewhere to land.
# Same branch as T-A.

# --- REQUIRED (generated by `vibe install`) ---------------------------
POSTGRES_PASSWORD=@POSTGRES_PASSWORD@
# 32-byte (64-hex) AES-256-GCM HKDF key. Used to encrypt the operator's
# Anthropic API key at rest in the DB. Rotating this orphans every
# encrypted secret in the DB — only do that if you're prepared to
# re-enter the Anthropic key from the admin UI.
MASTER_KEY=@MASTER_KEY@
JWT_SECRET=@JWT_SECRET@
JWT_REFRESH_SECRET=@JWT_REFRESH_SECRET@

# --- Image pin -------------------------------------------------------
IMAGE_TAG=@VIBE_TAX_VERSION@

# --- Database -------------------------------------------------------
POSTGRES_USER=vibe
POSTGRES_DB=vibe_tax

# --- Public origin (lib/apps.sh re-stamps this on mode switch) ------
PUBLIC_BASE_URL=https://@VIBE_HOST@

# --- Server ---------------------------------------------------------
LOG_LEVEL=info
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Bootstrap admin (applied by api on first boot if no users yet) -
# Empty values disable the seed; the operator then creates the first
# user via the /setup wizard at /tax/setup.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Skills repo (Phase 18) -----------------------------------------
SKILLS_REPO_URL=https://github.com/KisaesDevLab/Vibe-Claude-Tax-Research-Skills
SKILLS_REPO_PIN_TYPE=tag
SKILLS_REPO_PIN_VALUE=v1.0.0-beta

# --- Models manifest (Phase 22) -------------------------------------
MODELS_MANIFEST_URL=https://vibemb.com/manifests/anthropic-models.json

# --- Backups (Phase 27) ---------------------------------------------
BACKUP_RETENTION_DAYS=30

# --- Single-app host port publish (cleared in multi-app mode) -------
WEB_PUBLISH_PORT=8082

# --- Distribution mode (lib/mode.sh / install.sh override these) ----
VITE_BASE_PATH=/

# --- Licensing (lib/license.sh) -------------------------------------
DISABLE_LICENSE_CHECK=@DISABLE_LICENSE_CHECK@
LICENSE_PUBLIC_KEY_PATH=/etc/vibe/tax/license-public.pem
LICENSE_TOKEN=@LICENSE_TOKEN@
LICENSING_ENFORCED=false
