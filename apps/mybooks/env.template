# =====================================================================
# Vibe MyBooks — installer-managed environment file
# =====================================================================
# This template is rendered into /etc/vibe/mybooks/.env on first install.
# Placeholders surrounded by @VAR@ are filled in by lib/secrets.sh and
# lib/license.sh; everything else is the operator-tunable surface.
#
# After first install: hand-edit values you want to change, then run
#   sudo vibe upgrade mybooks       # reloads with the new env

# --- REQUIRED (generated by `vibe install`) ---------------------------
POSTGRES_PASSWORD=@POSTGRES_PASSWORD@
JWT_SECRET=@JWT_SECRET@
ENCRYPTION_KEY=@ENCRYPTION_KEY@
PLAID_ENCRYPTION_KEY=@PLAID_ENCRYPTION_KEY@

# --- Database --------------------------------------------------------
POSTGRES_USER=kisbooks
POSTGRES_DB=kisbooks

# --- Image pin (rolling minor by default; pin a tag in production) --
VIBE_MYBOOKS_VERSION=@VIBE_MYBOOKS_VERSION@

# --- Distribution mode (set by lib/mode.sh on multi-app promotion) --
# Single-app defaults below. lib/mode.sh overrides these via the
# grouped overlay when the host transitions to multi-app mode.
PUBLIC_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
COOKIE_PATH=/
# COOKIE_SECURE=
# WEBAUTHN_RP_ID=

# --- Server ----------------------------------------------------------
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
TRUST_PROXY=

# --- Auth expirations -----------------------------------------------
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ADMIN_MAX_AGE=30m

# --- File storage ---------------------------------------------------
UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE_MB=10

# --- Password hashing -----------------------------------------------
BCRYPT_ROUNDS=12

# --- Licensing (lib/license.sh) -------------------------------------
# Set DISABLE_LICENSE_CHECK=0 once you've installed a real token.
DISABLE_LICENSE_CHECK=@DISABLE_LICENSE_CHECK@
LICENSE_PUBLIC_KEY_PATH=/etc/vibe/mybooks/license-public.pem
LICENSE_TOKEN=@LICENSE_TOKEN@

# --- Email (optional — set to enable outbound mail) ----------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# --- Plaid (optional — leave blank to disable bank connections) ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- LLM (optional — enables receipt OCR + AI categorization) ------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# --- Cloud storage OAuth (optional) --------------------------------
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
STORAGE_ENCRYPTION_KEY=
STORAGE_CACHE_DIR=/data/cache
STORAGE_CACHE_MAX_SIZE_GB=5

# --- Backup --------------------------------------------------------
BACKUP_DIR=/data/backups
BACKUP_ENCRYPTION_KEY=

# --- Tailscale (optional — set TS_AUTHKEY if not using `vibe install tailscale`) ---
TS_AUTHKEY=
TS_HOSTNAME=mybooks
TS_EXTRA_ARGS=--ssh=false
TAILSCALE_SOCKET_PATH=/var/run/tailscale/tailscaled.sock

# --- Cloudflare Tunnel (set by `vibe cloudflare attach mybooks ...`) ---
CLOUDFLARE_TUNNEL_TOKEN=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Hardening flags ------------------------------------------------
RATE_LIMIT_REDIS=0
STAFF_IP_ALLOWLIST_ENFORCED=0
STRIPE_WEBHOOK_IP_ALLOWLIST_ENFORCED=0
HIBP_DISABLED=0
HIBP_TIMEOUT_MS=3000

# --- Single-app host port publishes (cleared in multi-app mode) -----
DB_HOST_PORT=5434
REDIS_HOST_PORT=6379
VITE_PORT=5173

# --- Resource limits ------------------------------------------------
DB_MEM_LIMIT=1g
REDIS_MEM_LIMIT=256m
API_MEM_LIMIT=1g
WEB_MEM_LIMIT=128m
WORKER_MEM_LIMIT=512m
TS_MEM_LIMIT=128m
GLM_OCR_MEM_LIMIT=4g
GLM_OCR_START_PERIOD=180s
CLOUDFLARED_MEM_LIMIT=128m
