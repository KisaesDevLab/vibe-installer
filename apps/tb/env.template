# =====================================================================
# Vibe TB — installer-managed environment file
# =====================================================================
# Rendered into /etc/vibe/tb/.env on first install.

# --- REQUIRED (generated by `vibe install`) ---------------------------
DB_PASSWORD=@DB_PASSWORD@
JWT_SECRET=@JWT_SECRET@
ENCRYPTION_KEY=@ENCRYPTION_KEY@

# --- Image pin -------------------------------------------------------
IMAGE_TAG=@VIBE_TB_VERSION@

# --- Distribution mode (lib/mode.sh overrides on multi-app promote) -
VITE_BASE_PATH=/
ALLOWED_ORIGIN=
APP_BASE_URL=

# --- Auth ------------------------------------------------------------
JWT_EXPIRY=8h

# --- LLM (optional) -------------------------------------------------
ANTHROPIC_API_KEY=
STRICT_AI_URL_SAFETY=

# --- Node tuning -----------------------------------------------------
NODE_OPTIONS=--max-old-space-size=1024

# --- Licensing (lib/license.sh) -------------------------------------
DISABLE_LICENSE_CHECK=@DISABLE_LICENSE_CHECK@
LICENSE_PUBLIC_KEY_PATH=/etc/vibe/tb/license-public.pem
LICENSE_TOKEN=@LICENSE_TOKEN@

# --- Single-app host port publish (cleared in multi-app mode) -------
WEB_PUBLISH_PORT=8081

# --- Optional GLM-OCR profile (`vibe install glm-ocr` wires this) ---
OCR_IMAGE_TAG=latest
